{
  "name": "lazyprompt",
  "version": "1.1.0",
  "private": true,
  "description": "Turn a vague idea into an optimized copy-paste prompt for lazycodex/OmO $ulw-plan or $ulw-loop. Outputs prompt text only; never runs the target skill.",
  "license": "MIT",
  "author": {
    "name": "devswha",
    "url": "https://github.com/devswha"
  },
  "homepage": "https://github.com/devswha/lazyprompt",
  "repository": {
    "type": "git",
    "url": "https://github.com/devswha/lazyprompt.git"
  },
  "bugs": {
    "url": "https://github.com/devswha/lazyprompt/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --test",
    "version:check": "node scripts/sync-version.mjs --check",
    "version:sync": "node scripts/sync-version.mjs",
    "preversion": "npm test",
    "version": "node scripts/sync-version.mjs --release && git add plugins/lazyprompt/.codex-plugin/plugin.json CHANGELOG.md"
  }
}
